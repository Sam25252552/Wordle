<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Timed Wordle</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    text-align: center;
    background: #121213;
    color: white;
}

#game {
    padding-top: 20px;
}

#timer {
    font-size: 24px;
    margin-bottom: 20px;
}

.board {
    display: grid;
    grid-template-rows: repeat(6, 1fr);
    gap: 5px;
    width: 300px;
    margin: 0 auto 20px auto;
}

.row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 5px;
}

.tile {
    width: 55px;
    height: 55px;
    border: 2px solid #3a3a3c;
    font-size: 24px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    background: #121213;
}

.correct { background: #538d4e; border-color: #538d4e; }
.present { background: #b59f3b; border-color: #b59f3b; }
.absent  { background: #3a3a3c; border-color: #3a3a3c; }

.keyboard {
    width: 600px;
    max-width: 95%;
    margin: auto;
}

.key-row {
    display: flex;
    justify-content: center;
    margin-bottom: 5px;
}

.key {
    margin: 2px;
    padding: 10px 12px;
    border-radius: 4px;
    border: none;
    background: #818384;
    color: white;
    cursor: pointer;
    font-weight: bold;
}

.white-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: white;
    display: none;
    z-index: 999;
}
</style>
</head>
<body>

<div id="whiteScreen" class="white-screen"></div>

<div id="game">
    <div id="timer">Time: 05:00</div>
    <div class="board" id="board"></div>
    <div class="keyboard" id="keyboard"></div>
</div>

<script>
const WORDS = ["apple", "grape", "brick", "stone", "flame"];
const solution = WORDS[Math.floor(Math.random() * WORDS.length)];
const board = document.getElementById("board");
const keyboard = document.getElementById("keyboard");
const whiteScreen = document.getElementById("whiteScreen");
const timerDisplay = document.getElementById("timer");

let currentRow = 0;
let currentCol = 0;
let guesses = Array.from({ length: 6 }, () => Array(5).fill(""));
let gameOver = false;
let totalTime = 300;
let visible = true;

function createBoard() {
    for (let r = 0; r < 6; r++) {
        const row = document.createElement("div");
        row.className = "row";
        for (let c = 0; c < 5; c++) {
            const tile = document.createElement("div");
            tile.className = "tile";
            tile.id = `tile-${r}-${c}`;
            row.appendChild(tile);
        }
        board.appendChild(row);
    }
}

function createKeyboard() {
    const rows = [
        "QWERTYUIOP",
        "ASDFGHJKL",
        "ZXCVBNM"
    ];

    rows.forEach(row => {
        const rowDiv = document.createElement("div");
        rowDiv.className = "key-row";
        row.split("").forEach(letter => {
            const button = document.createElement("button");
            button.className = "key";
            button.textContent = letter;
            button.onclick = () => handleInput(letter);
            rowDiv.appendChild(button);
        });
        keyboard.appendChild(rowDiv);
    });

    const controlRow = document.createElement("div");
    controlRow.className = "key-row";

    const enter = document.createElement("button");
    enter.textContent = "ENTER";
    enter.className = "key";
    enter.onclick = submitGuess;

    const back = document.createElement("button");
    back.textContent = "⌫";
    back.className = "key";
    back.onclick = deleteLetter;

    controlRow.appendChild(enter);
    controlRow.appendChild(back);
    keyboard.appendChild(controlRow);
}

function handleInput(letter) {
    if (gameOver || !visible) return;
    if (currentCol < 5) {
        guesses[currentRow][currentCol] = letter;
        document.getElementById(`tile-${currentRow}-${currentCol}`).textContent = letter;
        currentCol++;
    }
}

function deleteLetter() {
    if (currentCol > 0) {
        currentCol--;
        guesses[currentRow][currentCol] = "";
        document.getElementById(`tile-${currentRow}-${currentCol}`).textContent = "";
    }
}

function submitGuess() {
    if (currentCol !== 5) return;
    const guess = guesses[currentRow].join("").toLowerCase();

    for (let i = 0; i < 5; i++) {
        const tile = document.getElementById(`tile-${currentRow}-${i}`);
        if (guess[i] === solution[i]) {
            tile.classList.add("correct");
        } else if (solution.includes(guess[i])) {
            tile.classList.add("present");
        } else {
            tile.classList.add("absent");
        }
    }

    if (guess === solution) {
        alert("You Win!");
        gameOver = true;
        return;
    }

    currentRow++;
    currentCol = 0;

    if (currentRow === 6) {
        alert("Game Over! Word was: " + solution);
        gameOver = true;
    }
}

document.addEventListener("keydown", e => {
    if (!visible) return;
    if (e.key === "Enter") submitGuess();
    else if (e.key === "Backspace") deleteLetter();
    else if (/^[a-zA-Z]$/.test(e.key)) handleInput(e.key.toUpperCase());
});

function startTimer() {
    const interval = setInterval(() => {
        if (gameOver) {
            clearInterval(interval);
            return;
        }

        totalTime--;
        const minutes = String(Math.floor(totalTime / 60)).padStart(2, "0");
        const seconds = String(totalTime % 60).padStart(2, "0");
        timerDisplay.textContent = `Time: ${minutes}:${seconds}`;

        if (totalTime <= 0) {
            clearInterval(interval);
            alert("Time's up!");
            gameOver = true;
        }
    }, 1000);
}

function visibilityCycle() {
    setInterval(() => {
        if (gameOver) return;

        visible = false;
        whiteScreen.style.display = "block";

        setTimeout(() => {
            visible = true;
            whiteScreen.style.display = "none";
        }, 60000);

    }, 63000);
}

createBoard();
createKeyboard();
startTimer();
visibilityCycle();
</script>

</body>
</html>
