const WORD_LENGTH = 5;
const MAX_GUESSES = 6;
const TOTAL_TIME = 5 * 60; // 5 minutes in seconds
const FLASH_DURATION = 3000; // 3 seconds
const HIDE_DURATION = 60000; // 1 minute

const ANSWER = "APPLE";

let currentGuess = "";
let currentRow = 0;
let timeLeft = TOTAL_TIME;
let isBoardVisible = true;
let gameEnded = false;

const board = document.getElementById("board")!;
const keyboard = document.getElementById("keyboard")!;
const timerDisplay = document.getElementById("timer")!;
const gameContainer = document.getElementById("game")!;

// Create board
for (let i = 0; i < WORD_LENGTH * MAX_GUESSES; i++) {
  const tile = document.createElement("div");
  tile.classList.add("tile");
  board.appendChild(tile);
}

// Create keyboard
const letters = "QWERTYUIOPASDFGHJKLZXCVBNM";
letters.split("").forEach(letter => {
  const key = document.createElement("div");
  key.textContent = letter;
  key.classList.add("key");
  key.addEventListener("click", () => handleInput(letter));
  keyboard.appendChild(key);
});

// Keyboard support
document.addEventListener("keydown", (e) => {
  if (e.key === "Enter") submitGuess();
  else if (e.key === "Backspace") removeLetter();
  else if (/^[a-zA-Z]$/.test(e.key)) handleInput(e.key.toUpperCase());
});

function handleInput(letter: string) {
  if (currentGuess.length < WORD_LENGTH && !gameEnded) {
    currentGuess += letter;
    updateBoard();
  }
}

function removeLetter() {
  currentGuess = currentGuess.slice(0, -1);
  updateBoard();
}

function updateBoard() {
  const tiles = document.querySelectorAll(".tile");
  for (let i = 0; i < WORD_LENGTH; i++) {
    const tile = tiles[currentRow * WORD_LENGTH + i];
    tile.textContent = currentGuess[i] || "";
  }
}

function submitGuess() {
  if (currentGuess.length !== WORD_LENGTH || gameEnded) return;

  const tiles = document.querySelectorAll(".tile");

  for (let i = 0; i < WORD_LENGTH; i++) {
    const tile = tiles[currentRow * WORD_LENGTH + i];
    const letter = currentGuess[i];

    if (ANSWER[i] === letter) {
      tile.classList.add("correct");
    } else if (ANSWER.includes(letter)) {
      tile.classList.add("present");
    } else {
      tile.classList.add("absent");
    }
  }

  if (currentGuess === ANSWER) {
    endGame("You Win!");
    return;
  }

  currentRow++;
  currentGuess = "";

  if (currentRow === MAX_GUESSES) {
    endGame("Game Over!");
  }
}

function endGame(message: string) {
  gameEnded = true;
  alert(message);
}

function updateTimer() {
  timerDisplay.textContent = `Time: ${timeLeft}s`;
  if (timeLeft <= 0) {
    endGame("Time's up!");
  }
  timeLeft--;
}

// Flash visibility logic
function visibilityLoop() {
  if (gameEnded) return;

  if (isBoardVisible) {
    gameContainer.classList.add("hidden");
    document.body.style.backgroundColor = "white";
    isBoardVisible = false;

    setTimeout(() => {
      gameContainer.classList.remove("hidden");
      document.body.style.backgroundColor = "#121213";
      isBoardVisible = true;
    }, HIDE_DURATION);
  }

  setTimeout(visibilityLoop, FLASH_DURATION + HIDE_DURATION);
}

// Start timer
setInterval(updateTimer, 1000);

// Start flashing cycle
setTimeout(() => {
  visibilityLoop();
}, FLASH_DURATION);
