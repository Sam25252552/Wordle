<!DOCTYPE html>
<html>
   <head>
      <meta charset="UTF-8" />
      <title>Timed Flash Wordle</title>
      <style>
         body {
         margin: 0;
         font-family: Arial, sans-serif;
         display: flex;
         flex-direction: column;
         align-items: center;
         justify-content: center;
         height: 100vh;
         background-color: #121213;
         color: white;
         }
         #game {
         display: flex;
         flex-direction: column;
         align-items: center;
         }
         .board {
         display: grid;
         grid-template-columns: repeat(5, 60px);
         gap: 5px;
         margin-bottom: 20px;
         }
         .tile {
         width: 60px;
         height: 60px;
         border: 2px solid #3a3a3c;
         display: flex;
         align-items: center;
         justify-content: center;
         font-size: 2rem;
         font-weight: bold;
         text-transform: uppercase;
         background-color: #121213;
         }
         .correct { background-color: #538d4e; }
         .present { background-color: #b59f3b; }
         .absent { background-color: #3a3a3c; }
         .keyboard {
         display: grid;
         grid-template-columns: repeat(10, 1fr);
         gap: 5px;
         }
         .key {
         padding: 10px;
         background-color: #818384;
         border-radius: 4px;
         text-align: center;
         cursor: pointer;
         user-select: none;
         }
         #timer {
         position: absolute;
         top: 10px;
         font-size: 1.2rem;
         }
         .hidden {
         visibility: hidden;
         }
      </style>
   </head>
   <body>
      <div id="timer"></div>
      <div id="game">
         <div class="board" id="board"></div>
         <div class="keyboard" id="keyboard"></div>
      </div>
      <script src="dist/game.js"></script>
   </body>
</html>
